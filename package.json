    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "~6.19.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
